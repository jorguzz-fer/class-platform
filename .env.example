# ---- Database ----
# Local dev via docker-compose (see docker-compose.yml)
DATABASE_URL="postgresql://classos:classos@localhost:5432/classos?schema=public"

# ---- Auth.js (NextAuth v5) ----
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-with-openssl-rand-base64-32"
# Base URL pública do app (em produção: https://app.classos.com)
AUTH_URL="http://localhost:3000"
# Atrás de proxy reverso (Coolify/Traefik, Nginx), confie no header Host.
# Já habilitado no código (trustHost: true); manter a env é reforço.
AUTH_TRUST_HOST="true"

# ---- Seed (super admin da plataforma) ----
# Usados apenas pelo prisma/seed.ts — nunca commite valores reais.
SEED_SUPERADMIN_EMAIL="admin@classos.local"
SEED_SUPERADMIN_PASSWORD="change-me-strong-password"

# ---- E-mail (Resend) ----
# Sem RESEND_API_KEY, o app usa o provider de desenvolvimento (loga no servidor).
# Para enviar de verdade, defina a chave (https://resend.com) e um remetente
# verificado. Nunca commite a chave real.
RESEND_API_KEY=""
EMAIL_FROM="ClassOS <no-reply@classos.app>"

# ---- IA (Anthropic / Claude) ----
# Sem ANTHROPIC_API_KEY, o app usa um provider de IA simulado (mock) — zero custo.
# Com a chave (https://console.anthropic.com), os recursos de IA usam o Claude.
# Disponível apenas para organizações com plano que libera IA (hasAiFeatures).
ANTHROPIC_API_KEY=""

# ---- WhatsApp (gateway HTTP genérico / n8n) ----
# Sem estas variáveis, o app usa um provider de WhatsApp simulado (loga no servidor).
# Defina ambas para enviar via um gateway HTTP (POST {to, text} com Bearer token).
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""

# ---- Automações (cron / n8n) ----
# Segredo para autorizar chamadas às rotas de automação (ex.: recuperar inativos).
# Sem ele, as rotas de automação ficam desabilitadas (503). Nunca commite o valor.
CRON_SECRET=""

# ---- Pagamentos (Fase 2) ----
# Sem PAYMENT_PROVIDER, o checkout usa um gateway simulado (mock) — confirma o
# pagamento por uma pagina interna, sem cobrar de verdade. Defina ao plugar um
# gateway real (Stripe, Mercado Pago, Pagar.me, etc.).
PAYMENT_PROVIDER=""
# Segredo para validar a assinatura (HMAC) do webhook de pagamento.
# Sem ele, /api/payments/webhook fica desabilitado (503). Nunca commite o valor.
PAYMENT_WEBHOOK_SECRET=""
